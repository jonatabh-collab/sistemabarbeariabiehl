# ============================================
# BANCO DE DADOS (Supabase)
# ============================================
# Copie a connection string do painel do Supabase
# Settings > Database > Connection string (URI)
DATABASE_URL="postgresql://postgres:SENHA@HOST:5432/postgres"

# ============================================
# AUTENTICAÇÃO (NextAuth.js)
# ============================================
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="SUBSTITUA_POR_UMA_CHAVE_SECRETA_FORTE"

# URL da aplicação (localhost para desenvolvimento)
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# E-MAIL (Resend)
# ============================================
# Obtenha em: https://resend.com → API Keys
RESEND_API_KEY="re_SUBSTITUA_PELA_SUA_CHAVE"

# Endereço de e-mail remetente
# No plano gratuito use: onboarding@resend.dev
EMAIL_FROM="noreply@resend.dev"

# ============================================
# CONFIGURAÇÕES OPCIONAIS
# ============================================
# Chave para autorizar chamadas de cron jobs
CRON_SECRET="SUBSTITUA_POR_UMA_CHAVE_SECRETA"
